# ==============================================================================
# MoodMarket Environment Configuration
# Copy this file to '.env' and fill in your custom credentials.
# ==============================================================================

# Server Environment Settings
ENVIRONMENT=development
ENV=development
DEBUG=true
API_KEY=moodmarket_secret_api_key_2026
SECRET_KEY=your-secret-key-here
CORS_ORIGINS=*
RATE_LIMIT_PER_MIN=100
ENFORCE_HTTPS=false
REQUEST_TIMEOUT_SECONDS=30

# Database & Cache Connection Parameters
# Local Development defaults (will fallback to sqlite if unreachable)
# TIMESCALEDB_URI=postgresql://postgres:postgres@localhost:5432/moodmarket
# REDIS_URI=redis://localhost:6379/0

# Docker Compose Network Connection Parameters (use these inside Docker)
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/moodmarket
TIMESCALEDB_URI=postgresql://postgres:postgres@postgres:5432/moodmarket
REDIS_URL=redis://redis:6379/0
REDIS_URI=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# Ingestion API Credentials (Leave as-is to use offline simulation/mock mode)
REDDIT_CLIENT_ID=mock_reddit_client_id
REDDIT_CLIENT_SECRET=mock_reddit_client_secret
REDDIT_USER_AGENT=moodmarket_scraper

NEWS_API_KEY=mock_news_api_key
OPENAI_API_KEY=mock_openai_api_key
